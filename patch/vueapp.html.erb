      '.fu-close-btn:hover { color:#374151; }',
      '@media (max-width:640px) { .fu-page { padding:16px; } .fu-modal { width:100%; margin:8px; } .fu-time-row { flex-direction:column; } .fu-time-row > div:last-child { width:100%; } }'
    ].join('\n');
    document.head.appendChild(style);
  }

  // ============================================================
  // API OPERATIONS
  // ============================================================
  function loadFollowUps() {
    FU.loading = true;
    renderPage();
    return Promise.all([apiCall('GET', ''), loadLabels()]).then(function(results) {
      var res = results[0];
      FU.followUps = res.data || [];
      FU.enabled = res.enabled === true;
      FU.loading = false;
      renderPage();
    }).catch(function(err) {
      FU.loading = false;
      renderPage();
      console.error('[FollowUp] Erro ao carregar:', err);
      showToast('Erro ao carregar follow-ups: ' + (err && err.error ? err.error : 'verifique o console'), 'error');
    });
  }

  function toggleEnabled() {
    apiCall('POST', '/toggle').then(function(res) {
      FU.enabled = res.enabled === true;
      renderPage();
      showToast(FU.enabled ? 'Follow-up ativado!' : 'Follow-up desativado!');
    }).catch(function(err) {
      console.error('[FollowUp] Erro ao toggle:', err);
      showToast('Erro ao alterar configuração', 'error');
    });
  }

  function saveFollowUp(data, id) {
    var method = id ? 'PATCH' : 'POST';
    var path = id ? ('/' + id) : '';
    return apiCall(method, path, data).then(function(res) {
      if (id) {
        var idx = FU.followUps.findIndex(function(f) { return f.id === id; });
        if (idx >= 0) FU.followUps[idx] = res.data;
      } else {
        FU.followUps.unshift(res.data);
      }
      renderPage();
      showToast(id ? 'Follow-up atualizado!' : 'Follow-up criado!');
      return res;
    });
  }

  function deleteFollowUp(id) {
    return apiCall('DELETE', '/' + id).then(function() {
      FU.followUps = FU.followUps.filter(function(f) { return f.id !== id; });
      renderPage();
      showToast('Follow-up excluído!');
    });
  }

  function toggleFollowUpActive(id, active) {
    return apiCall('PATCH', '/' + id, { active: active }).then(function(res) {
      var idx = FU.followUps.findIndex(function(f) { return f.id === id; });
      if (idx >= 0) FU.followUps[idx] = res.data;
      renderPage();
    });
  }

  // ============================================================
  // MODAL (Create/Edit)
  // ============================================================
  function openModal(item) {
    FU.editingItem = item || null;
    var overlay = document.createElement('div');
    overlay.className = 'fu-overlay';
    overlay.id = 'fu-modal-overlay';
    overlay.onclick = function(e) { if (e.target === overlay) closeModal(); };

    var isEdit = !!item;

    // Build label exclusion checkboxes
    var existingExcl = (item && item.excluded_labels) || [];
    var labelCheckHtml = '<label style="display:flex;align-items:center;gap:8px;padding:4px 8px;cursor:pointer;border-bottom:1px solid #f3f4f6;">' +
      '<input type="checkbox" class="fu-excl-no-label"' + (item && item.exclude_no_label ? ' checked' : '') + '>' +
      '<span style="font-style:italic;color:#6b7280;">Sem etiqueta</span></label>';
    FU.labels.forEach(function(lbl) {
      var title = lbl.title || '';
      var color = lbl.color || '#6b7280';
      var checked = existingExcl.indexOf(title) >= 0 ? ' checked' : '';
      labelCheckHtml += '<label style="display:flex;align-items:center;gap:8px;padding:4px 8px;cursor:pointer;">' +
        '<input type="checkbox" class="fu-excl-label" value="' + escHtml(title) + '"' + checked + '>' +
        '<span style="display:inline-block;width:12px;height:12px;border-radius:50%;background:' + escHtml(color) + ';flex-shrink:0;"></span>' +
        '<span>' + escHtml(title) + '</span></label>';
    });

    // Build hour options
    var hourOpts = function(sel) {
      var h = '<option value="">—</option>';
      for (var i = 0; i < 24; i++) {
        var lb = (i < 10 ? '0' : '') + i + ':00';
        h += '<option value="' + i + '"' + (sel === i ? ' selected' : '') + '>' + lb + '</option>';
      }
      return h;
    };

    // Build add-label dropdown
    var addLabelOpts = '<option value="">Nenhuma</option>';
    FU.labels.forEach(function(lbl) {
      var title = lbl.title || '';
      var sel = (item && item.add_label_on_send === title) ? ' selected' : '';
      addLabelOpts += '<option value="' + escHtml(title) + '"' + sel + '>' + escHtml(title) + '</option>';
    });

    var html = '<div class="fu-modal">' +
      '<div class="fu-modal-header"><h3>' + (isEdit ? 'Editar Follow-up' : 'Criar Follow-up') + '</h3>' +
      '<button class="fu-close-btn" onclick="document.getElementById(\'fu-modal-overlay\').remove()">&times;</button></div>' +
      '<div class="fu-modal-body">' +
        '<div class="fu-field"><label>Nome do Follow-up *</label>' +
        '<input type="text" id="fu-form-name" placeholder="Ex: Lembrete de retorno" value="' + escHtml(item ? item.name : '') + '"></div>' +
        '<div class="fu-field"><div class="fu-time-row">' +
        '<div><label>Tempo de espera *</label>' +
        '<input type="number" id="fu-form-delay" min="1" placeholder="30" value="' + (item ? item.delay_time : '') + '"></div>' +
        '<div><label>Unidade</label>' +
        '<select id="fu-form-unit"><option value="minutes"' + (item && item.delay_unit === 'hours' ? '' : ' selected') + '>Minutos</option>' +
        '<option value="hours"' + (item && item.delay_unit === 'hours' ? ' selected' : '') + '>Horas</option></select></div>' +
        '</div></div>' +
        '<div class="fu-field"><label>Mensagem *</label>' +
        '<textarea id="fu-form-message" placeholder="Olá {{contact.name}}, notamos que você nos enviou uma mensagem...">' + escHtml(item ? item.message : '') + '</textarea>' +
        '<div class="fu-help">Use variáveis para personalizar a mensagem. Clique para inserir:</div>' +
        '<div class="fu-vars">' +
        '<button type="button" class="fu-var-btn" data-var="{{contact.name}}">{{contact.name}}</button>' +
        '<button type="button" class="fu-var-btn" data-var="{{contact.first_name}}">{{contact.first_name}}</button>' +
        '<button type="button" class="fu-var-btn" data-var="{{contact.email}}">{{contact.email}}</button>' +
        '<button type="button" class="fu-var-btn" data-var="{{contact.phone_number}}">{{contact.phone_number}}</button>' +
        '<button type="button" class="fu-var-btn" data-var="{{conversation.id}}">{{conversation.id}}</button>' +
        '</div></div>' +
        '<div class="fu-field"><label>Excluir conversas com etiquetas</label>' +
        '<div class="fu-help" style="margin-bottom:8px">Conversas com essas etiquetas NÃO receberão follow-up</div>' +
        '<div id="fu-label-checkboxes" style="max-height:160px;overflow-y:auto;border:1px solid #d1d5db;border-radius:8px;padding:4px;">' +
        labelCheckHtml +
        '</div></div>' +
        '<div class="fu-field"><label>Horário de envio (Brasília)</label>' +
        '<div class="fu-help" style="margin-bottom:8px">Follow-up será enviado apenas dentro deste horário. Deixe vazio para enviar a qualquer hora.</div>' +
        '<div class="fu-time-row">' +
        '<div><label>Início</label><select id="fu-form-start-hour">' + hourOpts(item ? item.schedule_start_hour : null) + '</select></div>' +
        '<div><label>Fim</label><select id="fu-form-end-hour">' + hourOpts(item ? item.schedule_end_hour : null) + '</select></div>' +
        '</div></div>' +
        '<div class="fu-field"><label>Adicionar etiqueta ao enviar</label>' +
        '<div class="fu-help" style="margin-bottom:8px">Etiqueta adicionada automaticamente à conversa quando o follow-up for enviado</div>' +
        '<select id="fu-form-add-label" style="width:100%;padding:8px 12px;border:1px solid #d1d5db;border-radius:8px;font-size:14px;color:#1f2937;box-sizing:border-box;">' + addLabelOpts + '</select></div>' +
        (isEdit ? '<div class="fu-field" style="display:flex;align-items:center;gap:10px;">' +
        '<label class="fu-switch"><input type="checkbox" id="fu-form-active"' + (item.active ? ' checked' : '') + '>' +
        '<span class="fu-switch-slider"></span></label>' +
        '<span style="font-size:14px;color:#374151;">Ativo</span></div>' : '') +
      '</div>' +
      '<div class="fu-modal-footer">' +
      '<button class="fu-btn fu-btn-secondary" id="fu-btn-cancel">Cancelar</button>' +
      '<button class="fu-btn fu-btn-primary" id="fu-btn-save">' + (isEdit ? 'Salvar' : 'Criar') + '</button>' +
      '</div></div>';

    overlay.innerHTML = html;
    document.body.appendChild(overlay);
    setTimeout(function() { overlay.classList.add('fu-show'); }, 10);

    // Variable insertion buttons
    overlay.querySelectorAll('.fu-var-btn').forEach(function(btn) {
      btn.onclick = function() {
        var ta = document.getElementById('fu-form-message');
        var start = ta.selectionStart;
        var end = ta.selectionEnd;
        var v = btn.getAttribute('data-var');
        ta.value = ta.value.substring(0, start) + v + ta.value.substring(end);
        ta.focus();
        ta.selectionStart = ta.selectionEnd = start + v.length;
      };
    });

    document.getElementById('fu-btn-cancel').onclick = closeModal;
    document.getElementById('fu-btn-save').onclick = function() {
      var name = document.getElementById('fu-form-name').value.trim();
      var delay = parseInt(document.getElementById('fu-form-delay').value);
      var unit = document.getElementById('fu-form-unit').value;
      var message = document.getElementById('fu-form-message').value.trim();
      var activeEl = document.getElementById('fu-form-active');
      var active = activeEl ? activeEl.checked : true;

      if (!name) { showToast('Informe o nome do follow-up', 'error'); return; }
      if (!delay || delay < 1) { showToast('Informe o tempo de espera', 'error'); return; }
      if (!message) { showToast('Informe a mensagem', 'error'); return; }

      var btn = document.getElementById('fu-btn-save');
      btn.disabled = true;
      btn.textContent = 'Salvando...';

      // Collect new fields
      var excludedLabels = [];
      document.querySelectorAll('#fu-modal-overlay .fu-excl-label:checked').forEach(function(el) {
        excludedLabels.push(el.value);
      });
      var exclNoLabelEl = document.querySelector('#fu-modal-overlay .fu-excl-no-label');
      var excludeNoLabel = exclNoLabelEl ? exclNoLabelEl.checked : false;
      var startHourVal = document.getElementById('fu-form-start-hour').value;
      var endHourVal = document.getElementById('fu-form-end-hour').value;
      var startHour = startHourVal !== '' ? parseInt(startHourVal) : null;
      var endHour = endHourVal !== '' ? parseInt(endHourVal) : null;
      var addLabelVal = document.getElementById('fu-form-add-label').value;

      saveFollowUp({
        name: name, delay_time: delay, delay_unit: unit, message: message, active: active,
        excluded_labels: excludedLabels,
        exclude_no_label: excludeNoLabel,
        schedule_start_hour: startHour,
        schedule_end_hour: endHour,
        add_label_on_send: addLabelVal || null
      }, isEdit ? item.id : null)
        .then(function() { closeModal(); })
        .catch(function(err) {
          btn.disabled = false;
          btn.textContent = isEdit ? 'Salvar' : 'Criar';
          var msg = (err && err.errors) ? err.errors.join(', ') : 'Erro ao salvar';
          showToast(msg, 'error');
        });
    };

    document.getElementById('fu-form-name').focus();
  }

  function closeModal() {
    var overlay = document.getElementById('fu-modal-overlay');
    if (overlay) {
      overlay.classList.remove('fu-show');
      setTimeout(function() { overlay.remove(); }, 200);
    }
  }

  function confirmDelete(item) {
    var overlay = document.createElement('div');
    overlay.className = 'fu-overlay';
    overlay.id = 'fu-delete-overlay';

    overlay.innerHTML = '<div class="fu-modal" style="width:400px">' +
      '<div class="fu-modal-header"><h3>Excluir Follow-up</h3>' +
      '<button class="fu-close-btn" onclick="document.getElementById(\'fu-delete-overlay\').remove()">&times;</button></div>' +
      '<div class="fu-modal-body"><p style="margin:0;color:#374151;">Tem certeza que deseja excluir <strong>' + escHtml(item.name) + '</strong>?</p>' +
      '<p style="margin:8px 0 0;color:#6b7280;font-size:13px;">Esta ação não pode ser desfeita.</p></div>' +
      '<div class="fu-modal-footer">' +
      '<button class="fu-btn fu-btn-secondary" id="fu-del-cancel">Cancelar</button>' +
      '<button class="fu-btn fu-btn-danger" id="fu-del-confirm">Excluir</button>' +
      '</div></div>';

    document.body.appendChild(overlay);
    setTimeout(function() { overlay.classList.add('fu-show'); }, 10);

    document.getElementById('fu-del-cancel').onclick = function() {
      overlay.classList.remove('fu-show');
      setTimeout(function() { overlay.remove(); }, 200);
    };
    document.getElementById('fu-del-confirm').onclick = function() {
      var btn = document.getElementById('fu-del-confirm');
      btn.disabled = true;
      btn.textContent = 'Excluindo...';
      deleteFollowUp(item.id).then(function() {
        overlay.classList.remove('fu-show');
        setTimeout(function() { overlay.remove(); }, 200);
      }).catch(function() {
        btn.disabled = false;
        btn.textContent = 'Excluir';
        showToast('Erro ao excluir', 'error');
      });
    };
  }

  // ============================================================
  // PAGE RENDERING
  // ============================================================
  function renderPage() {
    var container = document.getElementById('fu-page-container');
    if (!container) return;

    if (FU.loading) {
      container.innerHTML = '<div class="fu-loading"><svg width="24" height="24" viewBox="0 0 24 24" style="animation:spin 1s linear infinite"><circle cx="12" cy="12" r="10" stroke="#d1d5db" stroke-width="3" fill="none"/><path d="M12 2a10 10 0 0 1 10 10" stroke="#1b83ff" stroke-width="3" fill="none" stroke-linecap="round"/></svg><style>@keyframes spin{to{transform:rotate(360deg)}}</style><p style="margin-top:12px">Carregando...</p></div>';
      return;
    }

    var html = '<div class="fu-page">' +
      '<div class="fu-page-header"><h2>⏰ Follow-up</h2>' +
      '<button class="fu-btn fu-btn-primary" id="fu-btn-create">+ Criar Follow-up</button></div>' +
      '<p class="fu-page-desc">Configure mensagens automáticas de follow-up. Quando você envia uma mensagem e o cliente não responde dentro do tempo configurado, o sistema envia automaticamente a mensagem de follow-up na conversa. Você pode criar vários follow-ups com tempos diferentes — eles serão enviados em cascata enquanto o cliente não responder.</p>' +
      '<div class="fu-toggle-row"><div class="fu-toggle-info">' +
      '<h4>Ativar sistema de Follow-up</h4>' +
      '<p>Quando ativado, as mensagens de follow-up serão enviadas automaticamente</p></div>' +
      '<label class="fu-switch"><input type="checkbox" id="fu-global-toggle"' + (FU.enabled ? ' checked' : '') + '>' +
      '<span class="fu-switch-slider"></span></label></div>';

    if (FU.followUps.length === 0) {
      html += '<div class="fu-empty"><div class="fu-empty-icon">📭</div>' +
        '<h4>Nenhum follow-up configurado</h4>' +
        '<p>Crie seu primeiro follow-up clicando no botão acima</p></div>';
    } else {
      html += '<table class="fu-table"><thead><tr>' +
        '<th>Nome</th><th>Tempo</th><th>Mensagem</th><th>Filtros</th><th>Status</th><th style="width:100px">Ações</th></tr></thead><tbody>';

      FU.followUps.forEach(function(fu) {
        var timeLabel = fu.delay_time + ' ' + (fu.delay_unit === 'hours' ? (fu.delay_time > 1 ? 'horas' : 'hora') : (fu.delay_time > 1 ? 'minutos' : 'minuto'));
        var preview = fu.message.length > 80 ? fu.message.substring(0, 80) + '...' : fu.message;

        html += '<tr>' +
          '<td><strong>' + escHtml(fu.name) + '</strong></td>' +
          '<td>' + escHtml(timeLabel) + '</td>' +
          '<td><div class="fu-msg-preview">' + escHtml(preview) + '</div></td>' +
          '<td>';
        var filters = [];
        var exclLabels = fu.excluded_labels || [];
        if (exclLabels.length > 0 || fu.exclude_no_label) {
          var cnt = exclLabels.length + (fu.exclude_no_label ? 1 : 0);
          filters.push('🏷️ ' + cnt + ' excl.');
        }
        if (fu.schedule_start_hour != null && fu.schedule_end_hour != null) {
          var sh = fu.schedule_start_hour < 10 ? '0' + fu.schedule_start_hour : '' + fu.schedule_start_hour;
          var eh = fu.schedule_end_hour < 10 ? '0' + fu.schedule_end_hour : '' + fu.schedule_end_hour;
          filters.push('🕐 ' + sh + 'h-' + eh + 'h');
        }
        if (fu.add_label_on_send) {
          filters.push('➕ ' + escHtml(fu.add_label_on_send));
        }
        if (filters.length > 0) {
          filters.forEach(function(f) {
            html += '<span style="display:inline-block;padding:2px 8px;background:#f3f4f6;border-radius:12px;font-size:11px;margin:2px;">' + f + '</span>';
          });
        } else {
          html += '<span style="color:#9ca3af;font-size:12px;">—</span>';
        }
        html += '</td>' +
          '<td><label class="fu-switch"><input type="checkbox" data-toggle-id="' + fu.id + '"' + (fu.active ? ' checked' : '') + '>' +
          '<span class="fu-switch-slider"></span></label></td>' +
          '<td><div class="fu-actions">' +
          '<button class="fu-btn-icon" data-edit-id="' + fu.id + '" title="Editar">' +
          '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M11 4H4a2 2 0 00-2 2v14a2 2 0 002 2h14a2 2 0 002-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 013 3L12 15l-4 1 1-4 9.5-9.5z"/></svg></button>' +
          '<button class="fu-btn-icon danger" data-delete-id="' + fu.id + '" title="Excluir">' +
          '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 6h18"/><path d="M19 6v14a2 2 0 01-2 2H7a2 2 0 01-2-2V6m3 0V4a2 2 0 012-2h4a2 2 0 012 2v2"/><line x1="10" y1="11" x2="10" y2="17"/><line x1="14" y1="11" x2="14" y2="17"/></svg></button>' +
          '</div></td></tr>';
      });
      html += '</tbody></table>';
    }

    html += '</div>';
    container.innerHTML = html;

    // Event bindings
    var createBtn = document.getElementById('fu-btn-create');
    if (createBtn) createBtn.onclick = function() { openModal(null); };

    var toggleInput = document.getElementById('fu-global-toggle');
    if (toggleInput) toggleInput.onchange = function() { toggleEnabled(); };

    container.querySelectorAll('[data-toggle-id]').forEach(function(el) {
      el.onchange = function() {
        var id = parseInt(el.getAttribute('data-toggle-id'));
        toggleFollowUpActive(id, el.checked);
      };
    });

    container.querySelectorAll('[data-edit-id]').forEach(function(el) {
      el.onclick = function() {
        var id = parseInt(el.getAttribute('data-edit-id'));
        var item = FU.followUps.find(function(f) { return f.id === id; });
        if (item) openModal(item);
      };
    });

    container.querySelectorAll('[data-delete-id]').forEach(function(el) {
      el.onclick = function() {
        var id = parseInt(el.getAttribute('data-delete-id'));
        var item = FU.followUps.find(function(f) { return f.id === id; });
        if (item) confirmDelete(item);
      };
    });
  }

  // ============================================================
  // SIDEBAR INJECTION & PAGE MANAGEMENT
  // ============================================================
  function isSettingsPage() {
    return /\/accounts\/\d+\/settings/.test(window.location.pathname);
  }

  function showFollowUpPage() {
    if (FU.pageVisible) return;
    FU.pageVisible = true;

    // Find the settings content area and overlay it
    var appContainer = document.getElementById('app');
    if (!appContainer) return;

    // Create overlay positioned over the content area only
    var page = document.createElement('div');
    page.id = 'fu-page-root';
    page.style.cssText = 'position:fixed;top:0;left:0;right:0;bottom:0;z-index:100;display:flex;flex-direction:column;background:var(--n-surface-1, #fff);overflow-y:auto;';

    page.innerHTML = '<div style="padding:16px 32px 0;border-bottom:1px solid var(--n-slate-4, #e5e7eb);background:var(--n-surface-1, #fff);">' +
      '<button class="fu-btn fu-btn-secondary fu-btn-sm" id="fu-back-btn" style="display:inline-flex;align-items:center;gap:6px;margin-bottom:12px;">' +
      '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 12H5"/><path d="M12 19l-7-7 7-7"/></svg>' +
      'Voltar às Configurações</button></div>' +
      '<div id="fu-page-container" style="flex:1;overflow-y:auto;"></div>';

    appContainer.parentNode.insertBefore(page, appContainer.nextSibling);
    appContainer.style.display = 'none';

    document.getElementById('fu-back-btn').onclick = function(e) {
      e.preventDefault();
      hideFollowUpPage();
      var accountId = getAccountId();
      if (accountId) {
        window.location.hash = '';
        history.pushState(null, '', '/app/accounts/' + accountId + '/settings/general');
        window.dispatchEvent(new PopStateEvent('popstate'));
      }
    };

    loadFollowUps();
  }

  function hideFollowUpPage() {
    FU.pageVisible = false;
    var root = document.getElementById('fu-page-root');
    if (root) root.remove();

    var app = document.getElementById('app');
    if (app) app.style.display = '';
  }

  function injectSidebarItem() {
    if (document.getElementById('fu-sidebar-link')) return;
    if (!isSettingsPage()) return;

    // Chatwoot v4.11 uses SidebarGroup/SidebarGroupLeaf components
    // The settings group renders as ul.sidebar-group-children containing links to /settings/
    var settingsList = null;

    // Strategy 1: Find ul.sidebar-group-children with settings links
    var lists = document.querySelectorAll('ul.sidebar-group-children');
    for (var i = 0; i < lists.length; i++) {
      if (lists[i].querySelector('a[href*="/settings/"]')) {
        settingsList = lists[i];
        break;
      }
    }

    // Strategy 2: Fallback - find any ul containing .child-item with settings links
    if (!settingsList) {
      var items = document.querySelectorAll('.child-item a[href*="/settings/"]');
      if (items.length > 0) {
        settingsList = items[0].closest('ul');
      }
    }

    // Strategy 3: Broader fallback
    if (!settingsList) {
      var allLinks = document.querySelectorAll('a[href*="/settings/general"]');
      for (var j = 0; j < allLinks.length; j++) {
        var parent = allLinks[j].closest('ul');
        if (parent && parent.querySelectorAll('li').length > 3) {
          settingsList = parent;
          break;
        }
      }
    }

    if (!settingsList) return;

    // Create li matching SidebarGroupLeaf structure
    var li = document.createElement('li');
    li.id = 'fu-sidebar-link';
    li.className = 'py-0.5 ltr:pl-2 rtl:pr-2 rtl:mr-3 ltr:ml-3 relative text-n-slate-11 child-item before:bg-n-slate-4 after:bg-transparent after:border-n-slate-4 before:left-0 rtl:before:right-0 min-w-0';

    li.innerHTML = '<a href="#follow-up" title="Follow-up" ' +
      'class="flex h-8 items-center gap-2 px-2 py-1 rounded-lg hover:bg-gradient-to-r from-transparent via-n-slate-3/70 to-n-slate-3/70 group min-w-0">' +
      '<span class="size-4 grid place-content-center rounded-full">' +
      '<svg class="size-4 inline-block" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>' +
      '</span>' +
      '<div class="flex-1 truncate min-w-0 text-sm">Follow-up</div>' +
      '</a>';

    li.querySelector('a').onclick = function(e) {
      e.preventDefault();
      e.stopPropagation();
      window.location.hash = 'follow-up';
      showFollowUpPage();
    };

    settingsList.appendChild(li);
  }

  // ============================================================
  // INITIALIZATION & ROUTING
  // ============================================================
  function checkRoute() {
    if (window.location.hash === '#follow-up' && isSettingsPage()) {
      showFollowUpPage();
    } else if (FU.pageVisible && window.location.hash !== '#follow-up') {
      hideFollowUpPage();
    }
  }

  function init() {
    if (FU.initialized) return;
    FU.initialized = true;

    injectStyles();

    // Observe DOM for sidebar injection
    var observer = new MutationObserver(function() {
      if (isSettingsPage()) {
        injectSidebarItem();
      }
    });
    observer.observe(document.body, { childList: true, subtree: true });

    // Periodic check for sidebar (fallback)
    setInterval(function() {
      if (isSettingsPage()) {
        injectSidebarItem();
      }
      // Clean up if navigated away from settings
      if (!isSettingsPage() && FU.pageVisible) {
        hideFollowUpPage();
      }
      // Remove sidebar link if not on settings
      if (!isSettingsPage()) {
        var link = document.getElementById('fu-sidebar-link');
        if (link) link.remove();
      }
    }, 2000);

    // Hash change routing
    window.addEventListener('hashchange', checkRoute);
    window.addEventListener('popstate', function() {
      setTimeout(checkRoute, 100);
    });

    // Check initial route
    setTimeout(checkRoute, 1000);
  }

  // Start when DOM is ready
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    setTimeout(init, 500);
  }
})();
    </script>
    <!-- ====== FIM: Sistema de Follow-up ====== -->


    <div id="app"></div>
    <noscript id="noscript">This app works best with JavaScript enabled.</noscript>
    <%= yield %>
    <% if @dashboard_scripts.present? %>
      <%= @dashboard_scripts.html_safe %>
    <% end %>
  </body>
</html>
