  // --- Status refresh ---
  async function refreshEvoStatus(instanceName) {
    var state = await evoGetStatus(instanceName);
    var badge = document.getElementById('evo-status-badge');
    var qrArea = document.getElementById('evo-qr-area');
    var connInfo = document.getElementById('evo-connected-info');
    var disconnectBtn = document.getElementById('evo-disconnect-btn');
    var restartBtn = document.getElementById('evo-restart-btn');

    if (!badge) return;

    if (state === 'open') {
      badge.textContent = 'Conectado';
      badge.style.background = '#065f46';
      badge.style.color = '#a7f3d0';
      if (qrArea) qrArea.style.display = 'none';
      if (connInfo) connInfo.style.display = 'block';
      if (disconnectBtn) disconnectBtn.style.display = 'inline-block';
      if (restartBtn) restartBtn.style.display = 'inline-block';
      // Stop QR polling if runnig
      if (evoSettingsState.qrInterval) {
        clearInterval(evoSettingsState.qrInterval);
        evoSettingsState.qrInterval = null;
      }
    } else {
      badge.textContent = state === 'connecting' ? 'Conectando...' : 'Desconectado';
      badge.style.background = state === 'connecting' ? '#92400e' : '#7f1d1d';
      badge.style.color = state === 'connecting' ? '#fde68a' : '#fecaca';
      if (qrArea) qrArea.style.display = 'block';
      if (connInfo) connInfo.style.display = 'none';
      if (disconnectBtn) disconnectBtn.style.display = 'none';
      if (restartBtn) restartBtn.style.display = 'inline-block';
      // Auto-generate QR if not already polling
      if (!evoSettingsState.qrInterval) {
        window.evoGenerateQR();
      }
    }
  }

  // --- Window-exposed functions ---
  window.evoRefreshStatus = function() {
    if (evoSettingsState.instanceName) refreshEvoStatus(evoSettingsState.instanceName);
  };

  window.evoGenerateQR = async function() {
    var inst = evoSettingsState.instanceName;
    if (!inst) return;
    var imgBox = document.getElementById('evo-qr-img-box');
    var timer = document.getElementById('evo-qr-timer');
    if (imgBox) imgBox.innerHTML = '<span style="opacity:0.5;">Gerando QR Code...</span>';

    var qrBase64 = await evoGetQR(inst);
    if (qrBase64) {
      var src = qrBase64.startsWith('data:') ? qrBase64 : 'data:image/png;base64,' + qrBase64;
      if (imgBox) imgBox.innerHTML = '<img src="' + src + '" style="max-width:280px;border-radius:8px;background:#fff;padding:8px;" />';
    } else {
      if (imgBox) imgBox.innerHTML = '<span style="color:#f59e0b;">Não foi possível gerar o QR Code. A instância pode já estar conectada ou indisponível.</span>';
    }

    // Poll for connection every 3s for 2 minutes
    var checks = 0;
    if (evoSettingsState.qrInterval) clearInterval(evoSettingsState.qrInterval);
    evoSettingsState.qrInterval = setInterval(async function() {
      checks++;
      if (timer) timer.textContent = 'Verificando conexão... (' + checks + '/40)';
      if (checks >= 40) {
        clearInterval(evoSettingsState.qrInterval);
        evoSettingsState.qrInterval = null;
        if (timer) timer.textContent = 'QR Code expirado. Clique em "Gerar Novo QR Code".';
        return;
      }
      var s = await evoGetStatus(inst);
      if (s === 'open') {
        clearInterval(evoSettingsState.qrInterval);
        evoSettingsState.qrInterval = null;
        refreshEvoStatus(inst);
        loadEvoProfileData(inst);
        loadEvoProxyData(inst);
        showEvoFeedback('WhatsApp conectado com sucesso!', true);
      }
    }, 3000);
  };

  window.evoDisconnect = async function() {
    var inst = evoSettingsState.instanceName;
    if (!inst) return;
    if (!confirm('Deseja realmente desconectar o WhatsApp desta instância?')) return;
    showEvoFeedback('Desconectando...', true);
    await evoLogout(inst);
    setTimeout(function() { refreshEvoStatus(inst); }, 2000);
  };

  window.evoRestartInstance = async function() {
    var inst = evoSettingsState.instanceName;
    if (!inst) return;
    showEvoFeedback('Reiniciando instância...', true);
    await evoRestart(inst);
    setTimeout(function() { refreshEvoStatus(inst); }, 3000);
  };

  window.evoSaveProfileName = async function() {
    var v = document.getElementById('evo-profile-name').value.trim();
    if (!v) return showEvoFeedback('Nome é obrigatório', false);
    var ok = await evoUpdateProfileName(evoSettingsState.instanceName, v);
    showEvoFeedback(ok ? 'Nome atualizado!' : 'Erro ao atualizar nome', ok);
    if (ok) { var el = document.getElementById('evo-profile-display-name'); if (el) el.textContent = v; }
  };

  window.evoSaveProfileStatus = async function() {
    var v = document.getElementById('evo-profile-status').value.trim();
    var ok = await evoUpdateProfileStatus(evoSettingsState.instanceName, v);
    showEvoFeedback(ok ? 'Status atualizado!' : 'Erro ao atualizar status', ok);
    if (ok) { var el = document.getElementById('evo-profile-display-status'); if (el) el.textContent = v || '-'; }
  };

  window.evoSaveProfilePicture = async function() {
    var v = document.getElementById('evo-profile-picture-url').value.trim();
    if (!v) return showEvoFeedback('URL da imagem é obrigatória', false);
    var ok = await evoUpdateProfilePicture(evoSettingsState.instanceName, v);
    showEvoFeedback(ok ? 'Foto atualizada!' : 'Erro ao atualizar foto', ok);
    if (ok) {
      var img = document.getElementById('evo-profile-img');
      var ph = document.getElementById('evo-profile-img-placeholder');
      if (img) { img.src = v; img.style.display = 'block'; }
      if (ph) ph.style.display = 'none';
    }
  };

  window.evoDeleteProfilePicture = async function() {
    var ok = await evoRemoveProfilePicture(evoSettingsState.instanceName);
    showEvoFeedback(ok ? 'Foto removida!' : 'Erro ao remover foto', ok);
    if (ok) {
      var img = document.getElementById('evo-profile-img');
      var ph = document.getElementById('evo-profile-img-placeholder');
      if (img) { img.src = ''; img.style.display = 'none'; }
      if (ph) ph.style.display = 'flex';
    }
  };

  // --- Proxy functions ---
  async function evoFetchProxy(inst) {
    try {
      var r = await evoApi('/proxy/find/' + encodeURIComponent(inst));
      if (r.ok) return await r.json();
      return null;
    } catch(e) { return null; }
  }

  async function evoSetProxy(inst, proxyData) {
    var r = await evoApi('/proxy/set/' + encodeURIComponent(inst), {
      method: 'POST', body: JSON.stringify(proxyData)
    });
    return r.ok;
  }

  window.evoSaveProxy = async function() {
    var inst = evoSettingsState.instanceName;
    if (!inst) return;

    var enabled = document.getElementById('evo-proxy-enabled').checked;
    var host = document.getElementById('evo-proxy-host').value.trim();
    var port = document.getElementById('evo-proxy-port').value.trim();
    var protocol = document.getElementById('evo-proxy-protocol').value;
    var username = document.getElementById('evo-proxy-username').value.trim();
    var password = document.getElementById('evo-proxy-password').value.trim();

    if (enabled && (!host || !port)) {
      return showEvoFeedback('Host e Porta são obrigatórios', false);
    }

    var proxyData = { enabled: enabled, host: host, port: port, protocol: protocol, username: username, password: password };
    var ok = await evoSetProxy(inst, proxyData);
    showEvoFeedback(ok ? 'Proxy salvo com sucesso!' : 'Erro ao salvar proxy', ok);
  };

  async function loadEvoProxyData(instanceName) {
    try {
      var proxy = await evoFetchProxy(instanceName);
      if (proxy) {
        var enabledEl = document.getElementById('evo-proxy-enabled');
        var hostEl = document.getElementById('evo-proxy-host');
        var portEl = document.getElementById('evo-proxy-port');
        var protocolEl = document.getElementById('evo-proxy-protocol');
        var usernameEl = document.getElementById('evo-proxy-username');
        var passwordEl = document.getElementById('evo-proxy-password');
        var labelEl = document.getElementById('evo-proxy-enabled-label');

        if (enabledEl) { enabledEl.checked = proxy.enabled || false; }
        if (hostEl) hostEl.value = proxy.host || '';
        if (portEl) portEl.value = proxy.port || '';
        if (protocolEl) protocolEl.value = proxy.protocol || 'http';
        if (usernameEl) usernameEl.value = proxy.username || '';
        if (passwordEl) passwordEl.value = proxy.password || '';
        if (labelEl) labelEl.textContent = proxy.enabled ? 'Ativado' : 'Desativado';

        if (enabledEl) {
          enabledEl.addEventListener('change', function() {
            if (labelEl) labelEl.textContent = enabledEl.checked ? 'Ativado' : 'Desativado';
          });
        }
      }
    } catch(e) {
      console.log('[Evolution Settings] Proxy load error:', e);
    }
  }

  function showEvoFeedback(text, success) {
    var el = document.getElementById('evo-feedback');
    if (!el) return;
    el.textContent = text;
    el.style.display = 'block';
    el.style.background = success ? '#065f46' : '#7f1d1d';
    el.style.color = success ? '#a7f3d0' : '#fecaca';
    setTimeout(function() { el.style.display = 'none'; }, 4000);
  }

  async function loadEvoProfileData(instanceName) {
    try {
      var profile = await evoFetchProfile(instanceName);
      if (profile) {
        var nameEl = document.getElementById('evo-profile-name');
        var statusEl = document.getElementById('evo-profile-status');
        var displayName = document.getElementById('evo-profile-display-name');
        var displayStatus = document.getElementById('evo-profile-display-status');
        if (profile.name) {
          if (nameEl) nameEl.value = profile.name;
          if (displayName) displayName.textContent = profile.name;
        }
        if (profile.status) {
          if (statusEl) statusEl.value = profile.status;
          if (displayStatus) displayStatus.textContent = profile.status;
        }
        if (profile.isBusiness !== undefined) {
          if (displayStatus) displayStatus.textContent = (profile.status || '') + (profile.isBusiness ? ' (Business)' : '');
        }
      }
    } catch(e) {
      console.log('[Evolution Settings] Profile load error:', e);
    }

    // Try to load profile picture
    try {
      var inst = instanceName;
      var r = await evoApi('/chat/fetchProfilePictureUrl/' + encodeURIComponent(inst), {
        method: 'POST', body: JSON.stringify({ number: inst })
      });
      var d = await r.json();
      var picUrl = d.profilePictureUrl || d.picture || null;
      if (picUrl) {
        var img = document.getElementById('evo-profile-img');
        var ph = document.getElementById('evo-profile-img-placeholder');
        if (img) { img.src = picUrl; img.style.display = 'block'; }
        if (ph) ph.style.display = 'none';
      }
    } catch(e) {}
  }
  // ===== END EVOLUTION INBOX SETTINGS =====
  
  function init() {
    injectStyles();
    
    // Inject Evolution provider card on new inbox page
    setInterval(function() {
      if (!isInjected || !document.querySelector('[data-provider="evolution"]')) {
        isInjected = false;
        injectEvolutionProvider();
      }
    }, 1000);

    // Check for inbox config page (async, runs on URL change)
    var lastUrl = '';
    function checkRoute() {
      var currentUrl = window.location.href;
      if (currentUrl !== lastUrl) {
        lastUrl = currentUrl;
        // Reset injection state on navigation
        isInjected = false;
        cleanupEvoSettings();
        setTimeout(injectEvolutionProvider, 500);
        // Check if we're on an inbox settings page
        setTimeout(function() { checkInboxConfigPage(); }, 1200);
      }
    }
    
    // Initial check
    checkRoute();
    
    // Poll for URL changes (SPA routing)
    setInterval(checkRoute, 1500);
  }
  
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }
})();
    </script>

    <!-- Evolution: Detect Evolution inbox IDs from API responses -->
    <script>
(function() {
  // Store Evolution inbox IDs detected from API responses
  window.__evolutionInboxIds = new Set();

  const originalFetch = window.fetch;
  window.fetch = function(...args) {
    return originalFetch.apply(this, args).then(function(response) {
      const url = (typeof args[0] === 'string') ? args[0] : (args[0]?.url || '');

      // Intercept inboxes list to detect Evolution inbox IDs
      if (/\/api\/v1\/accounts\/\d+\/inboxes\/?(\?|$)/.test(url) && !url.includes('contactable_inboxes')) {
        const cloned = response.clone();
        cloned.json().then(function(data) {
          if (data && data.payload) {
            data.payload.forEach(function(inbox) {
              // Detect Channel::Api Evolution inboxes
              if (inbox.channel_type === 'Channel::Api' &&
                  inbox.provider_config &&
                  inbox.provider_config.provider_type === 'evolution') {
                window.__evolutionInboxIds.add(inbox.id);
              }
              // Fallback: legacy Channel::Whatsapp Evolution inboxes
              if (inbox.channel_type === 'Channel::Whatsapp' &&
                  inbox.provider_config &&
                  inbox.provider_config.provider_type === 'evolution') {
                window.__evolutionInboxIds.add(inbox.id);
              }
            });
          }
        }).catch(function() {});
        return response;
      }

      return response;
    });
  };
})();
    </script>

    <!-- ====== FarolChat: Sistema de Follow-up ====== -->
    <script>
(function() {
  'use strict';

  // ============================================================
  // CONFIG & STATE
  // ============================================================
  var FU = {
    initialized: false,
    pageVisible: false,
    followUps: [],
    enabled: false,
    loading: false,
    editingItem: null,
    labels: [],
    labelsLoaded: false
  };

  // ============================================================
  // HELPERS
  // ============================================================
  function getAccountId() {
    var m = window.location.pathname.match(/\/accounts\/(\d+)/);
    return m ? m[1] : null;
  }

  function getAuthHeaders() {
    // Strategy 1: Read cw_d_session_info cookie (set by js-cookie in Chatwoot dashboard)
    // Contains devise_token_auth response headers: access-token, token-type, client, expiry, uid
    try {
      var cookies = document.cookie.split(';');
      for (var i = 0; i < cookies.length; i++) {
        var c = cookies[i].trim();
        if (c.indexOf('cw_d_session_info=') === 0) {
          var rawVal = c.substring(18);
          // js-cookie v3 uses encodeURIComponent with some chars re-decoded
          // Try multiple decoding approaches
          var val;
          try { val = decodeURIComponent(rawVal); } catch(e) { val = rawVal; }
          // js-cookie may wrap in quotes
          if (val.charAt(0) === '"' && val.charAt(val.length - 1) === '"') {
            val = val.slice(1, -1);
          }
          // Handle escaped sequences from js-cookie read format
          val = val.replace(/(%[\dA-F]{2})+/gi, decodeURIComponent);
          var data = JSON.parse(val);
          if (data && data['access-token']) {
            return {
              'access-token': data['access-token'],
              'token-type': data['token-type'] || 'Bearer',
              'client': data['client'],
              'expiry': data['expiry'],
              'uid': data['uid']
            };
          }
        }
      }
    } catch(e) { console.warn('[FollowUp] Cookie parse error:', e); }

    // Strategy 2: Try to get from Vuex store's auth module via window.__vue_app__
    try {
      var appEl = document.getElementById('app');
      if (appEl && appEl.__vue_app__) {
        var vuexStore = appEl.__vue_app__.config.globalProperties.$store;
        if (vuexStore) {
          var currentUser = vuexStore.getters.getCurrentUser || vuexStore.state.auth && vuexStore.state.auth.currentUser;
          if (currentUser && currentUser.access_token) {
            return { 'api_access_token': currentUser.access_token };
          }
        }
      }
    } catch(e) { console.warn('[FollowUp] Vuex store read error:', e); }

    // Strategy 3: Try window.authToken (some Chatwoot versions expose this)
    try {
      if (window.authToken) {
        return { 'api_access_token': window.authToken };
      }
    } catch(e) {}

    console.error('[FollowUp] Nenhum método de autenticação encontrado. Cookie cw_d_session_info pode estar ausente.');
    return null;
  }

  function apiCall(method, path, body) {
    var accountId = getAccountId();
    var authHeaders = getAuthHeaders();
    if (!accountId || !authHeaders) {
      console.warn('[FollowUp] Sem autenticação. accountId:', accountId, 'authHeaders:', authHeaders);
      return Promise.reject('Sem autenticação');
    }

    var url = '/api/v1/accounts/' + accountId + '/follow_ups' + (path || '');
    var headers = { 'Content-Type': 'application/json' };
    // Merge devise auth headers
    Object.keys(authHeaders).forEach(function(k) { headers[k] = authHeaders[k]; });

    var opts = {
      method: method,
      headers: headers,
      credentials: 'same-origin'
    };
    if (body) opts.body = JSON.stringify(body);

    return fetch(url, opts).then(function(r) {
      if (r.status === 204) return null;
      if (!r.ok) {
        return r.text().then(function(text) {
          console.error('[FollowUp] API Error:', r.status, text);
          try { throw JSON.parse(text); } catch(e) { throw { error: text || ('HTTP ' + r.status) }; }
        });
      }
      return r.json();
    });
  }

  function loadLabels() {
    if (FU.labelsLoaded) return Promise.resolve(FU.labels);
    var accountId = getAccountId();
    var authHeaders = getAuthHeaders();
    if (!accountId || !authHeaders) return Promise.resolve([]);
    var url = '/api/v1/accounts/' + accountId + '/labels';
    var headers = { 'Content-Type': 'application/json' };
    Object.keys(authHeaders).forEach(function(k) { headers[k] = authHeaders[k]; });
    return fetch(url, { headers: headers, credentials: 'same-origin' })
      .then(function(r) { return r.json(); })
      .then(function(data) {
        FU.labels = data.payload || data || [];
        FU.labelsLoaded = true;
        return FU.labels;
      })
      .catch(function(e) {
        console.error('[FollowUp] Erro ao carregar labels:', e);
        return [];
      });
  }

  function showToast(msg, type) {
    var t = document.createElement('div');
    t.className = 'fu-toast fu-toast-' + (type || 'success');
    t.textContent = msg;
    document.body.appendChild(t);
    setTimeout(function() { t.classList.add('fu-toast-show'); }, 10);
    setTimeout(function() {
      t.classList.remove('fu-toast-show');
      setTimeout(function() { t.remove(); }, 300);
    }, 3000);
  }

  function escHtml(s) {
    var d = document.createElement('div');
    d.textContent = s || '';
    return d.innerHTML;
  }

