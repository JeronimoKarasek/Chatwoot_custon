      '.fu-field input:focus, .fu-field select:focus, .fu-field textarea:focus { border-color:#1b83ff; box-shadow:0 0 0 3px rgba(27,131,255,.1); }',
      '.fu-field textarea { min-height:100px; resize:vertical; }',
